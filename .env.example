# نسخة نموذجية — انسخها إلى .env.local واملأ القيم الحقيقية. لا تُرفع .env* إلى git.
# Copy to .env.local and fill real values. Never commit .env*.

# --- Next.js (browser-exposed; the anon key is a public/publishable key) ---
NEXT_PUBLIC_SUPABASE_URL=https://hiuhvgykuovrbuiqcqvi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# --- Supabase project (server / tooling; URL is not secret) ---
SUPABASE_URL=https://hiuhvgykuovrbuiqcqvi.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Server-only. NEVER commit. Used by trusted backend / Edge Functions when elevated.
SUPABASE_SERVICE_ROLE_KEY=server-only-never-commit

# Direct Postgres connection (migrations / CI). Get the password from Supabase dashboard.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.hiuhvgykuovrbuiqcqvi.supabase.co:5432/postgres

# OTP pepper — also set inside the DB:  ALTER DATABASE postgres SET app.otp_pepper='<random-secret>';
APP_OTP_PEPPER=change-me-to-a-long-random-secret
